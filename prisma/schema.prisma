generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// --- PARTE 1: LOOKUP TABLES (Reemplazan los enums) ---
// Usamos tablas lookup porque el connector SQL Server no soporta enums nativos.

model Sexo {
  id   Int    @id @default(autoincrement())
  clave String @unique @db.VarChar(5)
  label String @db.VarChar(50)
  solicitantes Solicitante[]
}

model Nacionalidad {
  id   Int    @id @default(autoincrement())
  clave String @unique @db.VarChar(5)
  label String @db.VarChar(50)
  solicitantes Solicitante[]
}

model EstadoCivil {
  id   Int    @id @default(autoincrement())
  clave String @unique @db.VarChar(30)
  label String @db.VarChar(100)
  solicitantes Solicitante[]
}

model CondicionTrabajo {
  id   Int    @id @default(autoincrement())
  clave String @unique @db.VarChar(30)
  label String @db.VarChar(100)
  solicitantes Solicitante[]
}

model CondicionActividad {
  id   Int    @id @default(autoincrement())
  clave String @unique @db.VarChar(30)
  label String @db.VarChar(100)
  solicitantes Solicitante[]
}


// --- PARTE 2: MODELOS (Tus tablas) ---

// Necesitamos definir la tabla "Nucleo" primero,
// ya que "Solicitante" depende de ella.
model Nucleo {
  // Asumo que la clave primaria de Nucleo es un "id" Entero
  id           Int           @id @default(autoincrement())
  NombreNucleo String?       @db.VarChar(100)

  // Esto crea la relación inversa:
  // Un Nucleo puede tener muchos Solicitantes
  solicitantes Solicitante[]
}

// Esta es la tabla de tu imagen
model Solicitante {
  // Atributos
  Fecha_Solicitud      DateTime
  ID_Nucleo            Int // El campo que guarda la llave foránea
  Nombre               String   @db.VarChar(40)
  Apellido             String   @db.VarChar(40)
  CI_Solicitante       String   @id @db.VarChar(10) // Esta es la Clave Primaria
  Telefono_Local       String   @db.VarChar(15)
  Telefono_Celular     String   @db.VarChar(15)
  Correo_Electronico   String   @unique @db.VarChar(254) // Añadí @unique, es buena práctica
  Comunidad_Residencia String   @db.VarChar(50)
  Parroquia_Residencia String   @db.VarChar(50)
  SexoId               Int
  sexo                 Sexo           @relation(fields: [SexoId], references: [id])
  Fecha_Nacimiento     DateTime
  NacionalidadId       Int
  nacionalidad         Nacionalidad   @relation(fields: [NacionalidadId], references: [id])
  EstadoCivilId        Int
  estadoCivil          EstadoCivil    @relation(fields: [EstadoCivilId], references: [id])
  Concubinato          Boolean
  Trabaja              Boolean
  CondicionTrabajoId   Int
  condicionTrabajo     CondicionTrabajo @relation(fields: [CondicionTrabajoId], references: [id])
  Buscando_Trabajo     Boolean
  CondicionActividadId Int
  condicionActividad   CondicionActividad @relation(fields: [CondicionActividadId], references: [id])

  // --- Relaciones (Tu Clave Foránea) ---
  // Le decimos a Prisma que ID_Nucleo apunta a la columna "id" de la tabla "Nucleo"
  nucleo Nucleo @relation(fields: [ID_Nucleo], references: [id])
}